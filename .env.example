# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
BASE_URL=http://localhost:3000
LOGO_URL=http://localhost:3000/logo.png

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/shak-bespoke-server_db

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_LENGTH=64
REFRESH_TOKEN_EXPIRES_DAYS=30

# ─── Mail (SMTP) ──────────────────────────────────────────────────────────────
MAIL_USER=your-email@example.com
MAIL_PASS=your-smtp-password

# ─── Seed / Super Admin ───────────────────────────────────────────────────────
SUPER_ADMIN_EMAIL=admin@example.com
SUPER_ADMIN_PASS=change-me

# ─── AWS S3 ───────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_S3_BUCKET_NAME=your-bucket-name

# ─── File Uploads ─────────────────────────────────────────────────────────────
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=10485760

# ─── Rate Limiting (global) ───────────────────────────────────────────────────
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# ─── Rate Limiting (auth endpoints) ──────────────────────────────────────────
LOGIN_MAX_ATTEMPTS=5
LOGIN_WINDOW_MS=900000
SIGNUP_MAX_ATTEMPTS=3
SIGNUP_WINDOW_MS=3600000
OTP_MAX_ATTEMPTS=5
OTP_WINDOW_MS=300000
PASSWORD_RESET_MAX_ATTEMPTS=3
PASSWORD_RESET_WINDOW_MS=3600000

# ─── Twilio ───────────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=your-account-sid
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# ─── Firebase Admin ───────────────────────────────────────────────────────────
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# ─── Docker (CI/CD only) ──────────────────────────────────────────────────────
DOCKER_USERNAME=your-dockerhub-username
PACKAGE_NAME=shak-bespoke-server
PACKAGE_VERSION=latest
