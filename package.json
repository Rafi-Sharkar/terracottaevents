    "eslint-plugin-prettier": "^5.5.6",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.4",
    "prisma": "^7.8.0",
    "semantic-release": "^25.0.5",
    "source-map-support": "^0.5.21",
    "ts-loader": "^9.6.0",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.61.0"
  }
}
