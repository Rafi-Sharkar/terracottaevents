    "cookie-parser": "^1.4.7",
    "dotenv": "^17.4.2",
    "firebase-admin": "^13.10.0",
    "google-auth-library": "^10.7.0",
    "he": "^1.2.0",
    "i": "^0.3.7",
    "ioredis": "^5.11.1",
    "jsonwebtoken": "^9.0.3",
    "luxon": "^3.7.2",
    "mime-types": "^3.0.2",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.10",
    "passport-jwt": "^4.0.1",
    "pg": "^8.21.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "sharp": "^0.35.1",
    "socket.io": "^4.8.3",
    "stripe": "^22.2.2",
    "twilio": "^5.13.1",
    "uuid": "^13.0.2",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.3",
