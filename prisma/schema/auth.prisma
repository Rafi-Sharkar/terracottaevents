model UserOtp {
  id        String   @id @default(uuid())
  code      String
  type      OtpType
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@index([userId])
  @@map("user_otps")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@map("refresh_tokens")
}

enum OtpType {
  EMAIL_VERIFICATION
  PHONE_VERIFICATION
  PASSWORD_RESET
}

model RateLimitAttempt {
  id         String   @id @default(uuid())
  identifier String
  action     String
  success    Boolean
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([identifier, action])
  @@index([createdAt])
  @@map("rate_limit_attempts")
}

